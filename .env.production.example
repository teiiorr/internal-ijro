# =========================================================================
# Production environment for Ichki Ijro
# Copy to .env.production on the server and fill in real values.
# Never commit a filled-in .env.production.
# =========================================================================

# --- App ---------------------------------------------------------------
NODE_ENV=production
# Public URL the app is served on (used for absolute links in emails etc).
APP_URL=https://ijro.bkrm.uz

# Port the Node.js process listens on internally (nginx proxies to this).
PORT=3000
HOSTNAME=127.0.0.1

# --- Database -----------------------------------------------------------
# Local Postgres on the same VPS:
DATABASE_URL=postgresql://ichki_ijro:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:5432/ichki_ijro
# Or UzCloud DBaaS:
# DATABASE_URL=postgresql://user:pass@db-host.uzcloud.uz:5432/ichki_ijro?sslmode=require

# --- NextAuth -----------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_BASE64_RANDOM_32_BYTES
# Same as APP_URL — NextAuth uses it for callback URLs:
AUTH_URL=https://ijro.bkrm.uz
# Trust the X-Forwarded-* headers nginx sets (we're behind a reverse proxy):
AUTH_TRUST_HOST=true

# --- Uploads (local FS) -------------------------------------------------
# Files live outside the project root so deploys don't wipe them.
UPLOAD_DIR=/var/lib/ichki-ijro/uploads
# Limit per-file upload size in bytes (default 25 MB):
MAX_UPLOAD_BYTES=26214400

# --- SMTP (notifications, password resets, invites) ---------------------
# Leave blank to silently no-op when nothing is configured.
SMTP_HOST=smtp.yandex.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=ichki-ijro@bkrm.uz
SMTP_PASS=CHANGE_ME_SMTP_APP_PASSWORD
SMTP_FROM="Ichki Ijro <ichki-ijro@bkrm.uz>"
